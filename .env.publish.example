# Chrome Web Store publish credentials — copy to .env.publish (gitignored) and fill in.
# See README "Publishing to the Chrome Web Store" for how to obtain each value.

# Extension ID from the Chrome Web Store dashboard (the item must already exist).
CWS_EXTENSION_ID=

# OAuth 2.0 Desktop client credentials (Google Cloud Console, Chrome Web Store API enabled).
CWS_CLIENT_ID=
CWS_CLIENT_SECRET=

# Long-lived refresh token minted once via the OAuth consent flow
# (e.g. `npx chrome-webstore-upload-keys`).
CWS_REFRESH_TOKEN=
