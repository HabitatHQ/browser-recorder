{
  "name": "browser-recorder",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npalladium/chrome-recorder.git"
  },
  "homepage": "https://github.com/npalladium/chrome-recorder",
  "bugs": {
    "url": "https://github.com/npalladium/chrome-recorder/issues"
  },
  "scripts": {
    "dev": "wxt --port 5555",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "package": "wxt zip && wxt zip -b firefox",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/generate-icons.mjs",
    "screenshots": "wxt build && node scripts/capture-screenshots.mjs",
    "build:cws": "./scripts/build-cws.sh",
    "publish:chrome": "./scripts/publish-chrome.sh",
    "lint": "biome check src",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@browser-recorder/core": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rrweb": "^2.0.1",
    "tailwind-merge": "^3.3.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.1.8",
    "@types/chrome": "^0.0.316",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@wxt-dev/module-react": "^1.1.5",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.6"
  }
}
