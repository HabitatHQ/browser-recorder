{
  "name": "browser-recorder",
  "version": "0.2.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt --port 5555",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "package": "wxt zip && wxt zip -b firefox",
    "check": "tsc --noEmit",
    "lint": "biome check src",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@browser-recorder/core": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.1.8",
    "@types/chrome": "^0.0.316",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@wxt-dev/module-react": "^1.1.5",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "wxt": "^0.20.6"
  }
}
